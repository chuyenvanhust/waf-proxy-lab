{
  "name": "WAF Proxy Lab",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "postCreateCommand": "chmod +x run/*.sh",
  "forwardPorts": [80],
  "portsAttributes": {
    "80": { "label": "WAF HTTP" }
  },
  "remoteEnv": {
    "DOCKER_BUILDKIT": "1"
  }
}
